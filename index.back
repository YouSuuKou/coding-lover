<!DOCTYPE html>
<html>
<head>
    <style>
        body {
            margin: 0;
            width: 100vw;
            height: 100vh;
            background: url('images/backgroup-image.jpg') fixed; /* 用fixed让所有页面背景固定 */
            background-size: cover;
        }

        .title {
            position: absolute;
            left: 50%;
            top: 25%;
            transform: translateX(-50%);
            color: rgb(0, 217, 255);
            -webkit-text-stroke: 0.25vw white;
            font-family: "Consolas", "Monaco", monospace;
            font-size: 6vw;
            text-align: center;
            width: 80%;
        }

        .subtitle {
            position: absolute;
            left: 50%;
            top: 45%;
            transform: translateX(-50%);
            color: rgb(0, 217, 255);
            -webkit-text-stroke: 0.15vw white;
            font-family: "Consolas", "Monaco", monospace;
            font-size: 3vw;
            text-align: center;
            width: 80%;
        }

        .toc-container {
            max-width: 80%;
            margin: 50px auto;
            font-family: "Times New Roman", "SimSun", serif;
        }

        .toc-title {
            text-align: center;
            color: red;
            -webkit-text-stroke: white 0.1rem;
            font-family: "Consolas",monospace;
            font-size: 4rem;
            margin-bottom: 2rem;
            border-bottom: 2px solid #fca5a5;
            padding-bottom: 0.5rem;
        }

        .toc-item {
            font-family: "Consolas",monospace;
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin: 1rem 0;
            padding: 0.3rem 0;
        }

        .toc-item::after {
            content: "";
            flex: 1;
            border-bottom: 1px dotted #ccc;
            margin: 0 10px;
        }

        .toc-chapter {
            font-size: 2.2rem;
            color: cyan;
            -webkit-text-stroke: rgb(255, 255, 255) 0.07rem;
            order: 1;
        }

        /* 层级缩进 */
        .toc-level-1 { margin-left: 0; }
        .toc-level-2 { margin-left: 2rem; }
        .toc-level-3 { margin-left: 4rem; }

        /* 悬停效果 */
        .toc-item:hover {
            background: #f5f5f5;
            cursor: pointer;
        }

        .content {
            max-width: 80%; /* 限制最大宽度保证可读性 */
            margin: 0 auto; /* 水平居中 */
            padding: 2rem;
    
            /* 文字排版 */
            font-family: "Consolas", "Monaco", monospace;
            line-height: 1.6; /* 行高，LaTeX党最爱的1.618滚蛋 */
            text-align: justify; /* 两端对齐 */
            color: #333;
        }
        
        p {
            margin-bottom: 1rem;
            font-size: 2rem;
            color: rgb(0, 0, 0);
            -webkit-text-stroke: rgb(0, 71, 171) 0.05rem;
        }

        .code-block {
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            padding: 1rem;
            border-radius: 4px;
            font-family: Consolas, monospace;
        }

        /* 响应式设计 */
        @media (max-width: 768px) {
            .content {
                max-width: 95%;
                padding: 1rem;
            }
    
            h1 { font-size: 2rem; }
            p { font-size: 1rem; }
        }

        .slide {
            width: 100%;
            height: 100%;
            display: none; /* 默认全隐藏 */
            position: absolute;
        }

        /* 第一页默认显示 */
        .slide:first-child {
            display: block;
        }
        .controls {
            position: fixed;
            z-index: 1000;
            padding: 15px;
            background: rgba(0,0,0,0.5);
            color: white;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            /* 触屏友好 */
            min-width: 80px;
            min-height: 50px;
        }

        .prev-btn {
            bottom: 20px;
            left: 20px;
        }

        .next-btn {
            bottom: 20px;
            right: 20px;
        }

        .fullscreen-btn {
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
        }

        /* 触屏设备优化 */
        @media (hover: none) and (pointer: coarse) {
            .controls {
                min-width: 100px;
                min-height: 60px;
                font-size: 1.8rem;
            }
        }
    </style>
    <title>Coding Lover</title>
</head>
<body>

<div class="slide" id="slide1">
    <h1 class="title">Coding Lover</h1>
    <h3 class="subtitle">Hobbies and Interests</h3>

    <button class="controls prev-btn" onclick="goPrev()">上一页</button>
    <button class="controls next-btn" onclick="goNext()">下一页</button>
    <button class="controls fullscreen-btn" onclick="toggleFullscreen()">全屏</button>
</div>

<div class="slide" id="slide2">
    <h1 class="toc-title">Index</h1>
    <div class="toc-item toc-level-1">
        <span class="toc-chapter">Beginning</span>
    </div>
    <div class="toc-item toc-level-1">
        <span class="toc-chapter">History</span>
    </div>
    <div class="toc-item toc-level-1">
        <span class="toc-chapter">Why Do I Love</span>
    </div>
    <div class="toc-item toc-level-1">
        <span class="toc-chapter">Ending</span>
    </div>

    <button class="controls prev-btn" onclick="goPrev()">上一页</button>
    <button class="controls next-btn" onclick="goNext()">下一页</button>
    <button class="controls fullscreen-btn" onclick="toggleFullscreen()">全屏</button>
</div>

<div class="slide" id="slide3">
    <h1 class="title">Beginning</h1>

    <button class="controls prev-btn" onclick="goPrev()">上一页</button>
    <button class="controls next-btn" onclick="goNext()">下一页</button>
    <button class="controls fullscreen-btn" onclick="toggleFullscreen()">全屏</button>
</div>

<div class="slide" id="slide4">
    <div class="content">
        <p>Everyone has a variety of hobbies and interests. Some love badminton and enjoy the thrill of smashing a powerful shot; some are passionate about cycling, experiencing speed and excitement on the road; others are devoted to science, eager to explore new knowledge and expand their horizons. As for me, I am deeply passionate about information technology, especially programming.</p>
    </div>

    <button class="controls prev-btn" onclick="goPrev()">上一页</button>
    <button class="controls next-btn" onclick="goNext()">下一页</button>
    <button class="controls fullscreen-btn" onclick="toggleFullscreen()">全屏</button>
</div>

<div class="slide" id="slide5">
    <h1 class="title">History</h1>

    <button class="controls prev-btn" onclick="goPrev()">上一页</button>
    <button class="controls next-btn" onclick="goNext()">下一页</button>
    <button class="controls fullscreen-btn" onclick="toggleFullscreen()">全屏</button>
</div>

<div class="slide" id="slide6">
    <div class="content">
        <p>I was first introduced to programming on September 1, 2023, when I started learning Scratch. Later, in September 2024, during my first IT lab class, I encountered the C++ language. Since then, I’ve learned about loops, if-else conditional statements, generating random numbers, and eventually moved away from using namespace std. I also discovered GitHub and, through conversations with AI, was introduced to LaTeX. My first open-source project was a book report written in LaTeX:https://github.com/gcc-404-NOT-FOUND/Red-Star-over-China</p>
    </div>

    <button class="controls prev-btn" onclick="goPrev()">上一页</button>
    <button class="controls next-btn" onclick="goNext()">下一页</button>
    <button class="controls fullscreen-btn" onclick="toggleFullscreen()">全屏</button>
</div>

<div class="slide" id="slide7">
    <h1 class="title">Why Do I Love</h1>

    <button class="controls prev-btn" onclick="goPrev()">上一页</button>
    <button class="controls next-btn" onclick="goNext()">下一页</button>
    <button class="controls fullscreen-btn" onclick="toggleFullscreen()">全屏</button>
</div>

<div class="slide" id="slide8">
    <div class="content">
        <p>Throughout my learning journey, I’ve adhered to the principle: If I can’t afford it or it’s not available, I’ll make it myself. I often spend at least three hours in one sitting while coding. I truly enjoy the sense of control over how the code runs and the output it produces. Every time I update my code, I feel a great sense of accomplishment.</p>
    </div>

    <button class="controls prev-btn" onclick="goPrev()">上一页</button>
    <button class="controls next-btn" onclick="goNext()">下一页</button>
    <button class="controls fullscreen-btn" onclick="toggleFullscreen()">全屏</button>
</div>

<div class="slide" id="slide9">
    <h1 class="title">Ending</h1>

    <button class="controls prev-btn" onclick="goPrev()">上一页</button>
    <button class="controls next-btn" onclick="goNext()">下一页</button>
    <button class="controls fullscreen-btn" onclick="toggleFullscreen()">全屏</button>
</div>

<div class="slide" id="slide10">
    <div class="content">
        <p>In summary, programming is the only hobby I’ve consistently pursued for over a year. I’m currently learning C++, LaTeX, and Python. If you also enjoy programming, feel free to chat with me! You can also follow my GitHub account:https://github.com/gcc-404-NOT-FOUND.</p>
    </div>

    <button class="controls prev-btn" onclick="goPrev()">上一页</button>
    <button class="controls next-btn" onclick="goNext()">下一页</button>
    <button class="controls fullscreen-btn" onclick="toggleFullscreen()">全屏</button>
</div>

<div class="slide" id="slide11">
    <h1 class="title">Thanks for Watching</h1>
    <h1 class="subtitle">Author:Administrator</h1>

    <button class="controls prev-btn" onclick="goPrev()">上一页</button>
    <button class="controls next-btn" onclick="goNext()">下一页</button>
    <button class="controls fullscreen-btn" onclick="toggleFullscreen()">全屏</button>
</div>

<script>
let currentSlide = 0;
const slides = document.querySelectorAll('.slide');

function goPrev() {
    // 调用你现有的上一页逻辑
    if (currentSlide > 0) {
        slides[currentSlide].style.display = 'none';
        currentSlide--;
        slides[currentSlide].style.display = 'block';
    }
}

function goNext() {
    // 调用你现有的下一页逻辑  
    if (currentSlide < slides.length - 1) {
        slides[currentSlide].style.display = 'none';
        currentSlide++;
        slides[currentSlide].style.display = 'block';
    }
}

function toggleFullscreen() {
    if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(err => {
            alert(`全屏请求失败: ${err.message}`);
        });
    } else {
        if (document.exitFullscreen) {
            document.exitFullscreen();
        }
    }
}


// 按空格翻页
document.addEventListener('keydown', (e) => {
    if (e.code === 'PageDown') {
        goNext;
    }
    if (e.code === 'PageUp' && currentSlide > 0) {
        goPrev;
    }
});
</script>

</body>
</html>